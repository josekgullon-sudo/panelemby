<%- include('../partials/header', { title: 'Resellers' }) %>

<h1>Resellers</h1>

<section class="panel">
  <h2>Nuevo reseller</h2>
  <form method="post" action="/admin/resellers" class="form-row">
    <input type="text" name="username" placeholder="usuario" required>
    <input type="password" name="password" placeholder="contraseña (mín. 6)" required>
    <button class="btn btn-primary">Crear</button>
  </form>
</section>

<% if (resellers.length === 0) { %>
  <p class="muted">No hay resellers todavía.</p>
<% } else { %>
<table>
  <tr><th>Usuario</th><th>Créditos</th><th>Cuentas</th><th>Estado</th><th>Acciones</th></tr>
  <% resellers.forEach(r => { %>
    <tr>
      <td><%= r.username %></td>
      <td><strong><%= r.credits %></strong></td>
      <td><%= r.accounts %></td>
      <td>
        <% if (r.is_active) { %><span class="badge badge-ok">activo</span>
        <% } else { %><span class="badge badge-err">suspendido</span><% } %>
      </td>
      <td class="actions">
        <details>
          <summary>Créditos</summary>
          <form method="post" action="/admin/resellers/<%= r.id %>/credits" class="form-row">
            <input type="number" name="amount" placeholder="+recarga / -ajuste" required>
            <button class="btn">Aplicar</button>
          </form>
        </details>
        <details>
          <summary>Contraseña</summary>
          <form method="post" action="/admin/resellers/<%= r.id %>/password" class="form-row">
            <input type="password" name="password" placeholder="nueva contraseña" required>
            <button class="btn">Cambiar</button>
          </form>
        </details>
        <form method="post" action="/admin/resellers/<%= r.id %>/toggle" class="inline">
          <button class="btn btn-ghost"><%= r.is_active ? 'Suspender' : 'Reactivar' %></button>
        </form>
      </td>
    </tr>
  <% }) %>
</table>
<% } %>

<%- include('../partials/footer') %>
