<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  <title>Iniciar sesión · Totalflix EMBY</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body class="login-page">
<div class="login-stage">
  <div class="login-glow" aria-hidden="true"></div>
  <div class="login-box">
    <div class="wordmark wordmark-lg">
      <span class="wordmark-total">TOTAL<em>FLIX</em></span>
      <span class="wordmark-emby">EMBY</span>
    </div>
    <p class="login-hint">Entra con tu usuario del panel o tu cuenta de Emby</p>
    <% if (error) { %><div class="flash flash-error" role="alert"><%= error %></div><% } %>
    <form method="post" action="/login">
      <label for="f-user">Usuario</label>
      <input id="f-user" type="text" name="username" required autofocus autocomplete="username">
      <label for="f-pass">Contraseña</label>
      <input id="f-pass" type="password" name="password" required autocomplete="current-password">
      <button class="btn btn-primary btn-block">Entrar</button>
    </form>
  </div>
</div>
</body>
</html>
