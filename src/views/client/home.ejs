<%- include('../partials/header', { title: 'Mi cuenta', nav: '' }) %>

<div class="client-hero">
  <div class="client-days <%= account.status !== 'active' ? 'is-expired' : days <= 7 ? 'is-warn' : '' %>">
    <div class="client-days-num"><%= account.status === 'active' ? Math.max(days, 0) : 0 %></div>
    <div class="client-days-label">días restantes</div>
  </div>
  <div class="client-summary">
    <h2>Hola, <%= account.username %></h2>
    <% if (account.status === 'active') { %>
      <%- include('../partials/meter', { days: days, duration: plan ? plan.duration_days : null }) %>
      <p class="client-line">Tu suscripción vence el <strong><%= account.expires_at.slice(0, 10) %></strong><% if (plan) { %> · Plan <strong><%= plan.name %></strong><% } %></p>
    <% } else { %>
      <p class="client-line">Tu suscripción venció el <strong><%= account.expires_at.slice(0, 10) %></strong></p>
    <% } %>
    <% if (account.status !== 'active') { %>
      <div class="flash flash-error">Tu cuenta ha caducado. Contacta con tu proveedor para renovarla.</div>
    <% } else if (days <= 7) { %>
      <div class="flash flash-error">Tu cuenta caduca en <%= days %> día<%= days === 1 ? '' : 's' %>. Contacta con tu proveedor para renovarla.</div>
    <% } %>
  </div>
</div>

<section class="panel">
  <div class="panel-head"><h2>Conéctate a Emby</h2></div>
  <table class="kv">
    <tr><th>Servidor</th><td><code><%= embyUrl %></code></td></tr>
    <tr><th>Usuario</th><td><code><%= account.username %></code></td></tr>
    <tr><th>Contraseña</th><td class="td-dim">la que te dio tu proveedor</td></tr>
    <% if (plan && plan.screens) { %>
      <tr><th>Pantallas</th><td><%= plan.screens %> reproducción<%= plan.screens === 1 ? '' : 'es' %> a la vez</td></tr>
    <% } %>
  </table>
  <p class="hint">Descarga la app de Emby en tu televisor, móvil u ordenador e introduce estos datos.</p>
</section>

<%- include('../partials/footer') %>
