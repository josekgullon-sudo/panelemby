<%- include('../partials/header', { title: 'Dashboard', nav: 'dashboard' }) %>

<div class="cards">
  <div class="card card-accent">
    <div class="card-label">Créditos disponibles</div>
    <div class="card-num"><%= stats.credits %></div>
  </div>
  <div class="card">
    <div class="card-label">Cuentas activas</div>
    <div class="card-num"><%= stats.active %></div>
  </div>
  <div class="card">
    <div class="card-label">Caducadas</div>
    <div class="card-num"><%= stats.expired %></div>
  </div>
</div>

<div class="columns">
  <section class="panel">
    <div class="panel-head">
      <h2>Caducan en 7 días</h2>
      <a class="panel-link" href="/reseller/cuentas">Mis cuentas →</a>
    </div>
    <% if (upcoming.length === 0) { %>
      <p class="empty">Ninguna cuenta caduca pronto. Todo en orden.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Cuenta</th><th>Vence</th><th class="th-meter">Tiempo restante</th></tr></thead>
        <tbody>
        <% upcoming.forEach(u => { const d = daysLeft(u.expires_at); %>
          <tr>
            <td class="td-strong"><%= u.username %></td>
            <td><%= d <= 0 ? 'Hoy' : u.expires_at.slice(0, 10) %></td>
            <td class="td-meter">
              <%- include('../partials/meter', { days: d, duration: u.duration_days }) %>
              <span class="meter-days"><%= d <= 0 ? 'hoy' : d + ' d' %></span>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>

  <section class="panel">
    <div class="panel-head"><h2>Últimos movimientos</h2></div>
    <% if (movements.length === 0) { %>
      <p class="empty">Sin movimientos. Cuando crees o renueves cuentas aparecerán aquí.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Fecha</th><th>Movimiento</th><th>Saldo</th></tr></thead>
        <tbody>
        <% movements.forEach(m => { %>
          <tr>
            <td class="td-dim"><%= m.created_at.slice(0, 16) %></td>
            <td class="<%= m.amount >= 0 ? 'pos' : 'neg' %>"><%= m.amount >= 0 ? '+' + m.amount : m.amount %></td>
            <td><%= m.balance_after %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</div>

<%- include('../partials/footer') %>
