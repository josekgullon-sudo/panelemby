# === Emby ===
# URL interna que usa el panel para hablar con la API de Emby
#   Desarrollo (Windows): http://187.124.208.99:8096
#   Producción (Ubuntu):  http://localhost:8096
EMBY_URL=http://187.124.208.99:8096

# API key de administrador de Emby (Panel de Emby -> Avanzado -> Claves de API)
EMBY_API_KEY=pon_aqui_tu_api_key

# URL que se muestra a los clientes finales como "datos de conexión".
# En producción normalmente es la URL pública del servidor, no localhost.
EMBY_PUBLIC_URL=http://187.124.208.99:8096

# === Panel ===
PORT=3000

# Cadena aleatoria larga para firmar las cookies de sesión.
# Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia_esto_por_una_cadena_aleatoria_larga

# Ruta del fichero SQLite (relativa a la raíz del proyecto)
DB_PATH=./data/panel.sqlite

# === Caducidades ===
# Días tras la caducidad para borrar la cuenta de Emby definitivamente. 0 = nunca borrar.
DELETE_AFTER_DAYS=15

# Cron del proceso diario de caducidades (formato cron de 5 campos, hora del servidor)
EXPIRY_CRON=30 4 * * *
